	"freeze": {
		"promptRevision": "role-prompts-v1",
		"resourceRevision": "calculator-role-resources-v1",
		"seed": 41001,
		"order": ["clean", "seeded", "holdout"],
		"deliveryAtMs": 50,
		"tools": ["read", "write", "edit", "bash"],
		"context": { "compaction": "disabled", "tokenCeiling": 60000 },
		"budgets": { "tokens": 60000, "wallMs": 600000, "outputChars": 120000 },
		"reviser": {
			"id": "fixed-reviser-v1",
			"provider": "fixture",
			"model": "reviser-v1",
			"effort": "high"
		}
	},
	"partitions": {
		"clean": {
			"visible": {
				"artifact": "A calculator implementation that already satisfies its declared behavior.",
				"instruction": "Preserve correct behavior and report only verified issues."
			},
			"authority": {
				"defectId": "CALC-CLEAN-000",
				"expectedFix": "none",
				"canary": "authority-calc-clean-x7",
				"mustInclude": ["verified"],
				"mustExclude": ["regression"]
			}
		},
		"seeded": {
			"visible": {
				"artifact": "A calculator implementation with one observable edge-case failure.",
				"instruction": "Find the root cause and verify the smallest complete correction."
			},
			"authority": {
				"defectId": "CALC-SEED-017",
				"expectedFix": "preserve operand replacement after equals",
				"canary": "authority-calc-seed-q4",
				"mustInclude": ["operand replacement verified"],
				"mustExclude": ["regression"]
			}
		},
		"holdout": {
			"visible": {
				"artifact": "A calculator implementation reserved for confirmation with an undisclosed invariant.",
				"instruction": "Use only visible behavior and produce independently verifiable evidence."
			},
			"authority": {
				"defectId": "CALC-HOLD-031",
				"expectedFix": "retain keyboard and button parity",
				"canary": "authority-calc-hold-p9",
				"mustInclude": ["input parity verified"],
				"mustExclude": ["regression"]
			}
		}
	}
}
